{
  "version": 2,
  "env": {
    "MONGODB_URI": "MongoDB connection string",
    "JWT_SECRET": "JWT secret key",
    "SOLANA_RPC_URL": "Solana RPC endpoint",
    "SOLANA_NETWORK": "Solana network name"
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    }
  ]
}
